# Environment variables for The Byte Array website
# Copy this file to .env and fill in the values

# Project name (used by docker-compose)
COMPOSE_PROJECT_NAME=thebytearray

# Node environment
NODE_ENV=production

# Docker image tag
IMAGE_TAG=latest

# Staging host (for deployment)
STAGING_HOST=staging.thebytearray.org

# Server configuration (for CI/CD deployment)
SERVER_HOST=
SERVER_USER=
STAGING_SERVER_HOST=
STAGING_SERVER_USER=
